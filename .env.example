DOL_API_KEY=

# BigQuery runtime
PROJECT_ID=cold-lead-pipeline-dashboard
BQ_DATASET=osha_raw
PUBLIC_PROJECT_ID=cold-lead-pipeline-dashboard
PUBLIC_BQ_DATASET=public_signals
RSS_PROJECT_ID=cold-lead-pipeline-dashboard
RSS_BQ_DATASET=rss_feed
RSS_FEED_URLS=osha_news|https://www.osha.gov/news/newsreleases.xml;fda_medwatch|https://www.fda.gov/about-fda/contact-fda/stay-informed/rss-feeds/medwatch/rss.xml;google_news_eye_safety|https://news.google.com/rss/search?q=%22eye%20injury%22%20OR%20%22eye%20protection%22%20OR%20%22protective%20eyewear%22%20OR%20%22safety%20glasses%22&hl=en-US&gl=US&ceid=US:en;google_news_prescription_safety|https://news.google.com/rss/search?q=%22prescription%20safety%20eyewear%22%20OR%20%22rx%20safety%20glasses%22%20OR%20%22osha%20eye%20protection%22&hl=en-US&gl=US&ceid=US:en
RSS_LOOKBACK_DAYS=30
RSS_MAX_ITEMS_PER_FEED=40
RSS_COMPANY_SEARCH_LIMIT=12
FDA_PROJECT_ID=cold-lead-pipeline-dashboard
FDA_BQ_DATASET=fda_raw
EPA_PROJECT_ID=cold-lead-pipeline-dashboard
EPA_BQ_DATASET=epa_raw
NIH_PROJECT_ID=cold-lead-pipeline-dashboard
NIH_BQ_DATASET=nih_raw
SINCE_DATE=

# API throughput controls
API_LIMIT=5000
API_MAX_PAGES=2
# Endpoint-specific override for accident feed (helps avoid 429s)
ACCIDENT_API_LIMIT=1000
ACCIDENT_API_MAX_PAGES=1
API_MIN_INTERVAL_SECONDS=1.0
API_TIMEOUT_SECONDS=120
API_MAX_RETRIES=5
API_BASE_BACKOFF_SECONDS=1.0
API_MAX_REQUESTS_PER_RUN=600
API_USER_AGENT=osha-sales-pipeline/1.0 (+ops@example.com)

# Compliance controls
COMPLIANCE_STRICT_MODE=true
DOL_API_TERMS_ACCEPTED=false
DOL_API_POLICY_URL=https://data.dol.gov/
DOL_API_POLICY_REVIEWED_ON=
DOL_API_CONTACT_EMAIL=
DOL_API_INTENDED_USE=
DATA_RETENTION_DAYS=365

