DOL_API_KEY=

# BigQuery runtime
PROJECT_ID=osha-data-live-20260303
BQ_DATASET=osha_raw
SINCE_DATE=

# API throughput controls
API_LIMIT=5000
API_MAX_PAGES=2
# Endpoint-specific override for accident feed (helps avoid 429s)
ACCIDENT_API_LIMIT=1000
ACCIDENT_API_MAX_PAGES=1
API_MIN_INTERVAL_SECONDS=1.0
API_TIMEOUT_SECONDS=120
API_MAX_RETRIES=5
API_BASE_BACKOFF_SECONDS=1.0
API_MAX_REQUESTS_PER_RUN=600
API_USER_AGENT=osha-sales-pipeline/1.0 (+ops@example.com)

# Compliance controls
COMPLIANCE_STRICT_MODE=true
DOL_API_TERMS_ACCEPTED=false
DOL_API_POLICY_URL=https://data.dol.gov/
DOL_API_POLICY_REVIEWED_ON=
DOL_API_CONTACT_EMAIL=
DOL_API_INTENDED_USE=
DATA_RETENTION_DAYS=365

