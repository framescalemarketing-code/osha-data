    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@types/node": "^24.0.1",
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^9.1.2",
